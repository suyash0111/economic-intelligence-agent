# NVIDIA NIM API Key (get from https://build.nvidia.com)
# One key works for all 7 models
NVIDIA_API_KEY=

# Email Configuration (Gmail with App Password)
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
RECIPIENT_EMAIL=

# Optional: Multiple recipients (comma-separated)
# RECIPIENT_EMAILS=email1@example.com,email2@example.com

# Report Settings
LOOKBACK_DAYS=7
MAX_ARTICLES_PER_ORG=20
